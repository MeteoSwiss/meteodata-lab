pipeline {
    options {
    // the variable $WORKSPACE is assigned dynamically at the beginning of every stage
    // and might change depending on the number of concurrent builds active.
    // The virtual environment is not relocatable.
        disableConcurrentBuilds()
    }
    agent {
        label 'balfrin'
    }

    environment {
        UENV_IMAGE = "fdb/5.19:v1"
    }

    post {
        always{
            echo 'Cleaning up workspace'
            deleteDir()
        }
    }

    stages {
        stage('setup env') {
            steps {
                sh '''#!/usr/bin/env bash
                set -x
                uenv image pull ${UENV_IMAGE}
                uenv run --view=remote-devt ${UENV_IMAGE} -- bash scripts/setup_poetry.sh
                '''
            }
        }

        stage('test') {
            steps {
                sh '''#!/usr/bin/env bash
                uenv run --view=remote-devt ${UENV_IMAGE} -- env -u GRIB_DEFINITION_PATH poetry run pytest tests
                '''
            }
        }

        stage('type check'){
            steps {
                sh '''#!/usr/bin/env bash
                uenv run --view=remote-devt ${UENV_IMAGE} -- poetry run mypy src tests
                '''
            }
        }

    }
}
